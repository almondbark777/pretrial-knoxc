# Copy to /etc/ptr-import.env, fill in, then: chmod 600 /etc/ptr-import.env
# Mailbox the Power Automate flow sends the PTR-EXPORT email to.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-dedicated-mailbox@gmail.com
IMAP_PASS=your_app_password_no_spaces
IMAP_FOLDER=INBOX
# Optional: only accept the export from this sender (your M365 address)
IMAP_FROM=
SUBJECT_TAG=PTR-EXPORT
SQLITE_DB_PATH=/opt/ptr-knoxc/db/kh222.db

# --- reconcile_import.py change-log email (optional) ---
# Recipients of the reconcile run report. Body is the PII-free summary; the full
# detail log is attached only when the tool is run with --attach-log.
# Defaults to support@retrobiscuit.org if left blank; override here to change.
REPORT_TO=support@retrobiscuit.org
# SMTP defaults derive from the IMAP_* values above (imap.gmail.com -> smtp.gmail.com,
# same user/app-password). Override only if your send path differs.
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASS=
#REPORT_FROM=
# Optional ntfy push for reconcile_import.py --ntfy (same topic as the ops alerts;
# also lives in /etc/ptr-alert.env). PII-free: only the note + headline counts.
#NTFY_URL=https://ntfy.sh/ptr-alerts-kc2847xq
