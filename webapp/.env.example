# Copy to .env and fill in your secrets.  .env is gitignored — never commit it.

# --- Database ---
# Path to the SQLite database file. Defaults to db/kh222.db next to the webapp.
# SQLITE_DB_PATH=/opt/ptr-knoxc/db/kh222.db

# --- Shared-password access gate ---
# Any user listed in webapp/users.py can log in using APP_PASSWORD.
# Usernames are case-insensitive.
APP_PASSWORD=pretrialtestsite

# Signing secret for the login session cookie. Generate one with:
#   openssl rand -hex 32
# If left blank it's derived from APP_PASSWORD (sessions reset on rotation).
# Set it explicitly in production.
APP_SESSION_SECRET=

# --- Go app: access control (Phase 7 admin/data-entry layer) ---
# Allow-list of @knoxsheriff.org emails that may sign in (comma/space separated).
# Leave UNSET to use the built-in 22-email default list.
# ALLOWED_EMAILS=daniel.harris@knoxsheriff.org, justin.webber@knoxsheriff.org

# Supervisor tier (subset of the allow-list) that may DELETE / RESTORE / OVERRIDE.
# Anyone not listed here is a regular officer (notes/tags/court-dates/etc. only).
# SUPERVISOR_EMAILS=alexander.bentley@knoxsheriff.org

# Cutover flag. false (default) = app-level delete is an importer-proof tombstone.
# Set true ONLY after SharePoint/importer is retired, to make delete a physical
# raw_* row delete. No other code change needed at cutover.
# IMPORTER_RETIRED=false

# --- Optional tuning ---
CACHE_TTL_SECONDS=60
