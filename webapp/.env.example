# Copy to .env and fill in your secrets.  .env is gitignored — never commit it.

# --- Database ---
# Path to the SQLite database file. Defaults to db/kh222.db next to the webapp.
# SQLITE_DB_PATH=/opt/ptr-knoxc/db/kh222.db

# --- Shared-password access gate ---
# Any user listed in webapp/users.py can log in using APP_PASSWORD.
# Usernames are case-insensitive.
APP_PASSWORD=pretrialtestsite

# Signing secret for the login session cookie. Generate one with:
#   openssl rand -hex 32
# If left blank it's derived from APP_PASSWORD (sessions reset on rotation).
# Set it explicitly in production.
APP_SESSION_SECRET=

# --- Optional tuning ---
CACHE_TTL_SECONDS=60
